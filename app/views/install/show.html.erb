<% content_for :title, "Instalar app — Save Puffendale" %>

<div
  class="container mx-auto my-6 px-4 max-w-lg min-h-[85vh]"
  data-controller="pwa-install"
>
  <h1 class="text-2xl font-bold text-center mb-4">
    Instalar o Save Puffendale
  </h1>

  <p class="text-center text-base-content/80 mb-6">
    Instale como app e abra em segundos, sem navegador.
  </p>

  <!-- Já instalado -->
  <div data-pwa-install-target="panelInstalled" class="hidden">
    <div class="alert alert-success shadow-lg">
      <span>Você já está usando o app instalado. Bom jogo!</span>
    </div>
  </div>

  <!-- iOS -->
  <div data-pwa-install-target="panelSafariIos" class="hidden">
    <div class="card bg-base-100 shadow-md">
      <div class="card-body gap-4">
        <h2 class="card-title text-lg">iPhone ou iPad</h2>

        <p class="text-sm text-base-content/80">
          Para instalar, use o botão de compartilhar:
        </p>

        <ol class="list-decimal list-inside space-y-2 text-sm">
          <li>
            Toque em <strong>Compartilhar</strong>
            <span class="inline-flex align-middle ml-1">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="10" width="14" height="9" rx="3" />
                <path d="M12 5V13" />
                <path d="M9 8L12 5L15 8" />
              </svg>
            </span>
          </li>
          <li>Toque em <strong>Adicionar à Tela de Início</strong>.</li>
          <li>Confirme em <strong>Adicionar</strong>.</li>
        </ol>
      </div>
    </div>
  </div>

  <!-- Safari Mac -->
  <div data-pwa-install-target="panelSafariMac" class="hidden">
    <div class="card bg-base-100 shadow-md">
      <div class="card-body gap-4">
        <h2 class="card-title text-lg">Mac (Safari)</h2>

        <p class="text-sm text-base-content/80">
          Adicione como app direto no Dock:
        </p>

        <ol class="list-decimal list-inside space-y-2 text-sm">
          <li>
            Clique em <strong>Compartilhar</strong>
            <span class="inline-flex align-middle ml-1">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="10" width="14" height="9" rx="3" />
                <path d="M12 5V13" />
                <path d="M9 8L12 5L15 8" />
              </svg>
            </span>
          </li>
          <li>Escolha <strong>Adicionar ao Dock</strong>.</li>
          <li>Confirme e abra pelo Dock.</li>
        </ol>
      </div>
    </div>
  </div>

  <!-- Chromium -->
  <div data-pwa-install-target="panelChromium" class="hidden">
    <div class="card bg-base-100 shadow-md">
      <div class="card-body gap-4">
        <h2 class="card-title text-lg">Chrome, Edge e similares</h2>

        <p class="text-sm text-base-content/80">
          Instale com um clique:
        </p>

        <button
          type="button"
          class="btn btn-primary w-full hidden"
          data-pwa-install-target="installButton"
          data-action="click->pwa-install#install"
        >
          Instalar app
        </button>

        <div data-pwa-install-target="chromiumFallback" class="hidden alert alert-warning">
          <span class="text-sm">
            Se o botão não aparecer, abra o menu (⋮) e toque em
            <strong>Instalar app</strong> ou <strong>Adicionar à tela inicial</strong>.
          </span>
        </div>

        <div data-pwa-install-target="installedToast" class="hidden alert alert-success mt-2">
          <span class="text-sm">
            App instalado. Abra pelo atalho criado.
          </span>
        </div>
      </div>
    </div>
  </div>
</div>